<script define:vars={{ content }}>
  const root = document.querySelector('.page');
  const buttons = document.querySelectorAll('[data-lang-btn]');

  function getValue(obj, path) {
    return path.split('.').reduce((acc, part) => acc && acc[part], obj);
  }

  function setLanguage(lang) {
    root.setAttribute('data-lang', lang);

    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      const value = getValue(content[lang], key);
      if (typeof value === 'string') {
        el.textContent = value;
      }
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
  const key = el.getAttribute('data-i18n-placeholder');
  const value = getValue(content[lang], key);
  if (typeof value === 'string') {
    el.setAttribute('placeholder', value);
  }
});

    document.querySelectorAll('[data-i18n-list]').forEach((el) => {
      const key = el.getAttribute('data-i18n-list');
      const value = getValue(content[lang], key);
      if (typeof value === 'string') {
        el.textContent = value;
      }
    });

    buttons.forEach((btn) => {
      btn.classList.toggle('active', btn.getAttribute('data-lang-btn') === lang);
    });

    localStorage.setItem('portfolio-lang', lang);
  }

  const saved = localStorage.getItem('portfolio-lang') || 'ru';
  setLanguage(saved);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      setLanguage(btn.getAttribute('data-lang-btn'));
    });
  });

    const feedbackModal = document.getElementById('feedbackModal');
  const openFeedbackModal = document.getElementById('openFeedbackModal');
  const closeFeedbackModal = document.getElementById('closeFeedbackModal');
  const feedbackBackdrop = document.getElementById('feedbackBackdrop');

  function openModal() {
    feedbackModal?.classList.add('is-open');
    feedbackModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    feedbackModal?.classList.remove('is-open');
    feedbackModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openFeedbackModal?.addEventListener('click', openModal);
  closeFeedbackModal?.addEventListener('click', closeModal);
  feedbackBackdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeModal();
    }
  });
</script>

