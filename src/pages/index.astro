---

<Layout title="Yesbol Zholdasbay | Portfolio">
  <main class="page" data-lang="ru">
    <header class="topbar">
      <a class="brand" href="#top">YZ</a>

      <nav class="nav">
        <a href="#about" data-i18n="nav.about">Обо мне</a>
        <a href="#experience" data-i18n="nav.experience">Опыт</a>
        <a href="#education" data-i18n="nav.education">Образование</a>
        <a href="#skills" data-i18n="nav.skills">Навыки</a>
        <a href="#projects" data-i18n="nav.projects">Проекты</a>
        <a href="#contact" data-i18n="nav.contact">Контакты</a>
      </nav>

      <div class="lang-switch">
        <button class="lang-btn active" data-lang-btn="ru">RU</button>
        <button class="lang-btn" data-lang-btn="en">EN</button>
      </div>
    </header>

    <section class="hero" id="top">
      <div class="hero-left">
        <div class="badge" data-i18n="hero.badge">Открыт к предложениям</div>
        <h1 data-i18n="hero.title">Есбол Жолдасбай</h1>
        <p class="role" data-i18n="hero.role">
          Системный администратор • DevOps инженер • Fullstack разработчик • Техподдержка
        </p>
        <p class="hero-text" data-i18n="hero.description">
          Я занимаюсь построением, поддержкой и улучшением IT-систем: Linux и Windows серверы, мониторинг, автоматизация, контейнеры, деплой, веб-приложения и процессы технической поддержки.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href={`${import.meta.env.BASE_URL}/cv/Yesbol-Zholdasbay-CV.pdf`} download data-i18n="hero.primary">Скачать резюме</a>
          <a class="btn btn-secondary" href="#contact" data-i18n="hero.secondary">Связаться</a>
          <a class="btn btn-ghost" href="https://github.com/xodnd99" target="_blank" rel="noreferrer" data-i18n="hero.github">GitHub</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="photo-card">
          <div class="photo-circle">
            <img src={`${import.meta.env.BASE_URL}/images/profile.jpg`} alt="Yesbol Zholdasbay" />
            <span class="photo-placeholder" data-i18n="hero.photoHint">Ваше фото</span>
          </div>

          <div class="quick-box">
            <h3 data-i18n="hero.quickTitle">Кратко обо мне</h3>
            <ul>
              <li data-i18n-list="hero.quickItems.0">Более 4 лет в IT</li>
              <li data-i18n-list="hero.quickItems.1">Алматы, Казахстан</li>
              <li data-i18n-list="hero.quickItems.2">Linux / DevOps / Support / Development</li>
              <li data-i18n-list="hero.quickItems.3">Двуязычное портфолио RU / EN</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="section-head">
        <span class="section-line"></span>
        <h2 data-i18n="about.title">Обо мне</h2>
      </div>
      <div class="card text-card">
        <p data-i18n="about.text1">
          Я IT-специалист с практическим опытом в системном администрировании, DevOps, технической поддержке и веб-разработке.
        </p>
        <p data-i18n="about.text2">
          Мой опыт включает администрирование Linux-серверов, мониторинг, автоматизацию, деплой в Docker, поддержку Windows-инфраструктуры, а также backend/frontend-разработку для бизнес-систем.
        </p>
        <p data-i18n="about.text3">
          Мне нравится практическая работа: решать инциденты, повышать стабильность систем, автоматизировать рутину и строить полезные и надежные решения.
        </p>
      </div>
    </section>
    <section class="section" id="education">
  <div class="section-head">
    <span class="section-line"></span>
    <h2 data-i18n="education.title">Образование</h2>
  </div>

  <div class="timeline">
    <article class="timeline-card">
      <div class="timeline-top">
        <h3 data-i18n="education.university">Алматинский университет энергетики и связи, вычислительная техника и программное обеспечение</h3>
        <span data-i18n="education.universityPeriod">Высшее образование</span>
      </div>
    </article>

    <article class="timeline-card">
      <div class="timeline-top">
        <h3 data-i18n="education.college">Алматинский Экономический Колледж, информационные системы, техник-программист</h3>
        <span data-i18n="education.collegePeriod">Среднее специальное</span>
      </div>
    </article>
  </div>
</section>

<section class="section" id="experience">
  <div class="section-head">
    <span class="section-line"></span>
    <h2 data-i18n="experience.title">Опыт</h2>
  </div>

  <div class="timeline">
    {content.ru.experience.items.map((item, index) => (
      <article class="timeline-card">
        <div class="timeline-top">
          <h3 data-i18n-list={`experience.items.${index}.company`}>{item.company}</h3>
          <span data-i18n-list={`experience.items.${index}.period`}>{item.period}</span>
        </div>
        <p class="timeline-role" data-i18n-list={`experience.items.${index}.role`}>
          {item.role}
        </p>
        <p data-i18n-list={`experience.items.${index}.text`}>
          {item.text}
        </p>
      </article>
    ))}
  </div>
</section>

    <section class="section" id="skills">
      <div class="section-head">
        <span class="section-line"></span>
        <h2 data-i18n="skills.title">Ключевые навыки</h2>
      </div>

      <div class="card">
        <div class="tags">
          {content.ru.skills.items.map((item) => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="projects">
      <div class="section-head">
        <span class="section-line"></span>
        <h2 data-i18n="projects.title">Избранные проекты</h2>
      </div>

      <div class="project-grid">
        <article class="project-card">
          <div class="project-number">01</div>
          <h3 data-i18n-list="projects.items.0.title">Медицинский портал</h3>
          <p data-i18n-list="projects.items.0.desc">
            Веб-проект для записи, медицинских данных и управляемых через админ-панель процессов.
          </p>
        </article>

        <article class="project-card">
          <div class="project-number">02</div>
          <h3 data-i18n-list="projects.items.1.title">Новостной сайт</h3>
          <p data-i18n-list="projects.items.1.desc">
            Веб-проект в формате CMS для публикации и управления новостным контентом.
          </p>
        </article>

        <article class="project-card">
          <div class="project-number">03</div>
          <h3 data-i18n-list="projects.items.2.title">Финансовый Telegram-бот</h3>
          <p data-i18n-list="projects.items.2.desc">
            Бот для ввода, хранения и визуализации финансовых данных компаний в виде графиков.
          </p>
        </article>
      </div>
    </section>

    <section class="section" id="contact">
      <div class="section-head">
        <span class="section-line"></span>
        <h2 data-i18n="contact.title">Контакты</h2>
      </div>

